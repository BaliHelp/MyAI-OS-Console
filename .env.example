# ════════════════════════════════════════════════════════════════════════════
# MyAI OS Console — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ════════════════════════════════════════════════════════════════════════════

# ── Supabase (share with other ecosystem apps, gateway_console schema is isolated) ──
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Use AIzaSy... key from aistudio.google.com (NOT AQ.Ab8... OAuth token — it expires in 1h)
GEMINI_API_KEY=AIzaSy<your-gemini-api-key>

# ── OpenAI GPT & Anthropic Claude (Auto-imported to DB on startup) ──────────────
OPENAI_API_KEY1=sk-proj-<your-openai-api-key-1>
CLAUDE_API_KEY1=sk-ant-sid01-<your-claude-api-key-1>
GROK_API_KEY1=xai-<your-grok-api-key-1>
DEEPSEEK_API_KEY1=sk-<your-deepseek-api-key-1>

# ── Auth & Session Security ────────────────────────────────────────────────────
# bcrypt hash of your admin password. Generate with: npm run generate-hash
# Example: bcryptjs.hashSync("your_password", 10)
ADMIN_PASSWORD_HASH=<your-bcrypt-hash>

# Admin email address allowed to login
ADMIN_EMAIL=rimbanusaonline@gmail.com

# Secret for signing JWT session cookies (generate: openssl rand -hex 32)
SESSION_SECRET=<64-char-hex-string>

# ── Provider Key Encryption ────────────────────────────────────────────────────
# AES-256 master key for encrypting upstream provider API keys in DB
# Must be exactly 32 characters
PROVIDER_KEY_ENCRYPTION_SECRET=<32-char-random-string>

# ── App URL ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
